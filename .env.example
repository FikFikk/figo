# ============================================================
# FiGo Environment Variables
# Copy file ini ke .env dan isi dengan nilai yang sebenarnya
# ============================================================

# TMDB API (Film & Netflix series — themoviedb.org)
# Get your API key: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_READ_ACCESS_TOKEN=your_tmdb_read_access_token_here

# RapidAPI key untuk Indonesia Stock Exchange (IDX) API
# Get your API key: https://rapidapi.com/
RAPIDAPI_KEY=your_rapidapi_key_here

# Google Safe Browsing API Key (Optional)
# Get your API key: https://developers.google.com/safe-browsing
GOOGLE_SAFE_BROWSING_KEY=your_google_api_key_here

# ============================================================
# STREAMING CONFIGURATION (FiGo Video Player)
# ============================================================

# Backend Go API URL (internal, default: http://127.0.0.1:5001)
GO_DOWNLOAD_API_URL=http://127.0.0.1:5001

# PIN Protection untuk akses streaming (4-6 digit recommended)
# User harus input PIN ini sebelum bisa akses video player
STREAM_PIN=1234

# Secret key untuk HMAC token (min 32 chars, generate dengan: openssl rand -hex 32)
# Digunakan untuk sign unlock token yang disimpan di httpOnly cookie
STREAM_SECRET=generate_random_64_char_hex_string_here

# ============================================================
# PRODUCTION SETTINGS (Optional)
# ============================================================

# Uncomment jika deploy ke production dengan HTTPS
# NODE_ENV=production
# NUXT_PUBLIC_SITE_URL=https://go.fikfikk.my.id

# ============================================================
# NOTES
# ============================================================
# 
# 1. TMDB_API_KEY & TMDB_READ_ACCESS_TOKEN
#    - Ambil dari https://www.themoviedb.org/settings/api
#    - Digunakan untuk fetch metadata film, series, anime
#    - Language default: id-ID (Indonesia)
#
# 2. STREAM_PIN & STREAM_SECRET
#    - PIN diverifikasi di server (tidak pernah dikirim ke client)
#    - Secret untuk HMAC signature unlock token
#    - Token valid 24 jam, disimpan di httpOnly cookie
#    - Cookie sameSite=none untuk support incognito mode
#
# 3. GO_DOWNLOAD_API_URL
#    - Internal URL ke backend Go (port 5001)
#    - Jangan expose ke public, hanya untuk Nuxt server
#
# 4. Security Best Practices
#    - Jangan commit .env ke Git (sudah ada di .gitignore)
#    - Rotate STREAM_SECRET secara berkala
#    - Gunakan PIN yang kuat (minimal 4 digit)
#    - Pastikan HTTPS di production untuk secure cookie
